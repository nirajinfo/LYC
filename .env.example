# Laxminiya Youth Club - Production Environment Configurations

# Database Settings (MySQL Production Database)
DATABASE_HOST=
DATABASE_PORT=3306
DATABASE_NAME=lyc_database
DATABASE_USER=root
DATABASE_PASSWORD=

# JWT Authentication
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# Gemini AI API Configuration
GEMINI_API_KEY=

# SMTP Configuration for Transactional/Notification Emails
# Set SMTP_USER to your Gmail (e.g., lycjahada@gmail.com) and SMTP_PASS to your App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=lycjahada@gmail.com
SMTP_PASS=

# Application URL
APP_URL=

